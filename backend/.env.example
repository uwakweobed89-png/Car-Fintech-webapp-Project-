# Port the API listens on (optional, defaults to 8080)
PORT=8080

# AWS region for Secrets Manager (optional, defaults to us-east-1)
AWS_REGION=us-east-1

# ARN of the Secrets Manager secret holding RDS credentials
# (host, port, dbname, username, password as JSON — see terraform/modules/vpc/secrets.tf)
# Leave unset to run against the built-in in-memory data instead of RDS.
DB_SECRET_ARN=

# Comma-separated list of allowed CORS origins. Leave unset only for local
# dev — an empty value makes the API accept requests from any origin.
ALLOWED_ORIGINS=

# Shared secret for admin-only endpoints (full purchase detail, including
# buyer email/loan/credit data). Send as the `X-Admin-Key` header. Leave
# unset to keep those endpoints locked — there is no open fallback.
ADMIN_API_KEY=
